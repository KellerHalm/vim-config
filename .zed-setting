{
    "agent_servers": {
        "codex": {
            
        },
        "qwen-code": {
            "type": "registry"
        },
        "your_agent": {
            "type": "custom",
            "command": "path_to_executable"
        }
    },
    "agent": {
        "default_model": {
            "enable_thinking": false,
            "provider": "openai",
            "model": "gpt-5.2-codex"
        },
        "favorite_models": [],
        "inline_assistant_model": {
            "provider": "google",
            "model": "gemini-3.0-pro"
        },
        "model_parameters": []
    },
    "autosave": {
        "after_delay": {
            "milliseconds": 1000,
        },
    },
    "context_servers": {
        "mcp-server-context7": {
            "enabled": true,
            "settings": {
                "context7_api_key": "",
            },
        },
        "mcp-server-github": {
            "enabled": true,
            "settings": {
                "github_personal_access_token": "",
            },
        },
    },

    "icon_theme": {
        "mode": "dark",
        "light": "Catppuccin Macchiato",
        "dark": "Catppuccin Macchiato",
    },
    "theme": {
        "mode": "dark",
        "light": "Catppuccin Iced Latte (Blur) [Heavy]",
        "dark": "Catppuccin Mocha (Blur) [Heavy]",
    },
    "theme_overrides": {
        "Catppuccin Mocha (Blur) [Heavy]": {
            "editor.document_highlight.read_background": "#00000000",
            "editor.document_highlight.write_background": "#00000000",
            "border.variant": "#00000000",
            "border": "#00000000",
            "panel.focused_border": "#00000000",
            "players": [
                {
                    "cursor": "#b4befe",
                },
            ],
            "syntax": {
                "comment": {
                    "font_style": "italic",
                },
                "comment.doc": {
                    "font_style": "italic",
                },
            },
        },
    },

    "base_keymap": "VSCode",

    "ui_font_size": 22.0,
    "ui_font_family": "Dank Mono",

    "buffer_font_size": 22.0,
    "buffer_font_family": "Dank Mono",
    "buffer_line_height": {
        "custom": 2.5,
    },

    "relative_line_numbers": "enabled",

    "agent_ui_font_size": 18,
    "agent_buffer_font_size": 18,

    "cursor_shape": "bar",
    "cursor_blink": false,
    "selection_highlight": false,

    "drag_and_drop_selection": {
        "enabled": false,
    },

    "current_line_highlight": "none",
    "show_whitespaces": "none",
    "tab_size": 4,
    "show_completions_on_input": false,
    "inline_code_actions": false,
    "format_on_save": "off",
    
    "tab_bar": {
        "show": false,
    },

    "project_panel": {
        "dock": "right",
        "default_width": 400,
        "hide_root": true,
        "auto_fold_dirs": false,
        "starts_open": false,
        "git_status": false,
        "sticky_scroll": false,
        "scrollbar": {
            "show": "never",
        },
        "indent_guides": {
            "show": "never",
        },
    },

    "outline_panel": {
        "default_width": 300,
        "indent_guides": {
            "show": "never",
        },
    },

    "file_finder": {
        "modal_max_width": "large",
    },

    "scrollbar": {
        "show": "never",
    },

    "gutter": {
        "min_line_number_digits": 0,
        "folds": false,
        "runnables": false,
    },

    "indent_guides": {
        "enabled": false,
    },
}
